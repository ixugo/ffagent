{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main", "settings"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "allow-agent-port",
    "allow-open-settings",
    "opener:default",
    "shell:default",
    "dialog:default",
    "fs:default",
    "process:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://127.0.0.1:*" },
        { "url": "http://localhost:*" }
      ]
    }
  ]
}
