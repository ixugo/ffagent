{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "FFAgent default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "allow-agent-port",
    "allow-open-settings",
    "opener:default",
    "dialog:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "agent",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "shell:allow-stdin-write"
  ]
}
